<Window
    x:Class="FileExplorer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileExplorer.App"
    xmlns:views="using:FileExplorer.App.Views"
    xmlns:converters="using:FileExplorer.App.Converters">

    <Grid>
        <Grid.Resources>
            <SolidColorBrush x:Key="TreeViewItemBackgroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TreeViewItemBackgroundPressed" Color="Transparent" />
            <SolidColorBrush x:Key="TreeViewItemBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TreeViewItemBorderBrushPressed" Color="Transparent" />
            <Style x:Key="SubtleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
            </Style>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" IsInverted="True" />
            <converters:FileSizeConverter x:Key="FileSizeConverter" />
            <converters:CloudStatusToIconConverter x:Key="CloudStatusIconConverter" />
            <converters:CloudStatusToToolTipConverter x:Key="CloudStatusToolTipConverter" />
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: Tab strip (title bar) -->
            <RowDefinition Height="40" />    <!-- Row 1: Navigation bar -->
            <RowDefinition Height="40" />    <!-- Row 2: Command bar -->
            <RowDefinition Height="*" />     <!-- Row 3: Main content -->
            <RowDefinition Height="24" />    <!-- Row 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ROW 0: Tab Strip in Title Bar -->
        <TabView
            x:Name="TabViewControl"
            Grid.Row="0"
            IsAddTabButtonVisible="True"
            AddTabButtonClick="TabView_AddTabButtonClick"
            TabCloseRequested="TabView_TabCloseRequested"
            SelectionChanged="TabView_SelectionChanged"
            CanDragTabs="True"
            CanReorderTabs="True"
            TabWidthMode="Equal"
            VerticalAlignment="Stretch" />

        <!-- ROW 1: Navigation Bar -->
        <Grid Grid.Row="1" Padding="4,0" ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button x:Name="BackButton" Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Back (Alt+Left)" Click="BackButton_Click"
                        IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
                        Width="32" Height="32" Padding="0">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <Button x:Name="ForwardButton" Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Forward (Alt+Right)" Click="ForwardButton_Click"
                        IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}"
                        Width="32" Height="32" Padding="0">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72A;" FontSize="14" />
                </Button>
                <Button x:Name="UpButton" Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Up (Backspace)" Click="UpButton_Click"
                        IsEnabled="{x:Bind ViewModel.CanGoUp, Mode=OneWay}"
                        Width="32" Height="32" Padding="0">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74A;" FontSize="14" />
                </Button>
                <Button x:Name="RefreshButton" Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Refresh (F5)" Click="RefreshButton_Click"
                        Width="32" Height="32" Padding="0">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </StackPanel>

            <!-- Address / breadcrumb bar (Grid with breadcrumb overlay + hidden edit box) -->
            <Grid x:Name="AddressBarArea" Grid.Column="1" VerticalAlignment="Center"
                  CornerRadius="4" BorderThickness="1"
                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                  Background="{ThemeResource ControlFillColorDefaultBrush}"
                  MinHeight="32"
                  Tapped="AddressBarArea_Tapped">
                <!-- Breadcrumb row (visible by default) -->
                <ScrollViewer x:Name="BreadcrumbScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Auto"
                              Background="Transparent">
                    <StackPanel x:Name="BreadcrumbPanel"
                                Orientation="Horizontal"
                                Spacing="0"
                                Padding="4,0"
                                Background="Transparent" />
                </ScrollViewer>
                <!-- Edit box (hidden, shown when clicked) -->
                <AutoSuggestBox x:Name="AddressBar"
                                QueryIcon="Forward" PlaceholderText="Enter a path..."
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                QuerySubmitted="AddressBar_QuerySubmitted"
                                SuggestionChosen="AddressBar_SuggestionChosen"
                                TextChanged="AddressBar_TextChanged"
                                LostFocus="AddressBar_LostFocus"
                                KeyDown="AddressBar_KeyDown" />
            </Grid>

            <AutoSuggestBox x:Name="SearchBox" Grid.Column="2"
                            QueryIcon="Find" PlaceholderText="Search..."
                            VerticalAlignment="Center"
                            QuerySubmitted="SearchBox_QuerySubmitted" />
        </Grid>

        <!-- ROW 2: Command Bar -->
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" IsOpen="False" OverflowButtonVisibility="Auto">
            <AppBarButton Icon="Add" Label="New" ToolTipService.ToolTip="Create new item">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Folder" Click="NewFolder_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8B7;" /></MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="N" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:Name="CutButton" ToolTipService.ToolTip="Cut (Ctrl+X)" Click="Cut_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8C6;" /></AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Modifiers="Control" Key="X" /></AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="CopyButton" ToolTipService.ToolTip="Copy (Ctrl+C)" Click="Copy_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8C8;" /></AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Modifiers="Control" Key="C" /></AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="PasteButton" ToolTipService.ToolTip="Paste (Ctrl+V)" Click="Paste_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE77F;" /></AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Modifiers="Control" Key="V" /></AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarButton x:Name="RenameButton" ToolTipService.ToolTip="Rename (F2)" Click="Rename_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8AC;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="ShareButton" ToolTipService.ToolTip="Share" Click="Share_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE72D;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="DeleteButton" ToolTipService.ToolTip="Delete" Click="Delete_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;" /></AppBarButton.Icon>
                <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Key="Delete" /></AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton Label="Sort" ToolTipService.ToolTip="Sort by">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8CB;" /></AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Name" Click="SortByName_Click" />
                        <MenuFlyoutItem Text="Date modified" Click="SortByDate_Click" />
                        <MenuFlyoutItem Text="Type" Click="SortByType_Click" />
                        <MenuFlyoutItem Text="Size" Click="SortBySize_Click" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton Label="View" ToolTipService.ToolTip="View options">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8A9;" /></AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <ToggleMenuFlyoutItem x:Name="PreviewPaneToggle" Text="Preview pane" Click="TogglePreviewPane_Click" />
                        <MenuFlyoutSeparator />
                        <ToggleMenuFlyoutItem x:Name="HiddenFilesToggle" Text="Show hidden items" Click="ToggleHiddenFiles_Click" />
                        <ToggleMenuFlyoutItem x:Name="FileExtensionsToggle" Text="Show file name extensions" Click="ToggleFileExtensions_Click" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Select all" Click="SelectAll_Click">
                    <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Modifiers="Control" Key="A" /></AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <AppBarButton Label="Undo" Click="Undo_Click">
                    <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Modifiers="Control" Key="Z" /></AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton Label="Properties" Click="Properties_Click">
                    <AppBarButton.KeyboardAccelerators><KeyboardAccelerator Modifiers="Menu" Key="Enter" /></AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- ROW 3: Main Content -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="315" MinWidth="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: Navigation Tree using ItemsSource -->
            <TreeView
                x:Name="NavigationTree"
                Grid.Column="0"
                SelectionMode="Single"
                ItemInvoked="NavigationTree_ItemInvoked"
                RightTapped="NavigationTree_RightTapped"
                Expanding="NavigationTree_Expanding"
                Collapsed="NavigationTree_Collapsed"
                Padding="8,4,4,4" />

            <!-- Splitter -->
            <Border Grid.Column="1" Width="4" Background="Transparent"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    ManipulationMode="TranslateX"
                    ManipulationDelta="TreeSplitter_ManipulationDelta" />

            <!-- Right Pane: File List -->
            <views:FileListView x:Name="FileList" Grid.Column="2" />

            <!-- Preview Pane -->
            <Grid x:Name="PreviewPaneGrid" Grid.Column="3" Padding="12"
                  BorderThickness="1,0,0,0"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <Image x:Name="PreviewImage" MaxHeight="400" Stretch="Uniform" Visibility="Collapsed" />
                        <ScrollViewer x:Name="PreviewTextScroller" MaxHeight="600" Visibility="Collapsed">
                            <TextBlock x:Name="PreviewText" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                        <TextBlock x:Name="NoPreviewText" Text="Select a file to preview"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ROW 4: Status Bar -->
        <Grid Grid.Row="4" Padding="12,0"
              BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusBarLeft" Grid.Column="0" FontSize="11"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="StatusBarRight" Grid.Column="1" FontSize="11"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,12,0" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button Style="{StaticResource SubtleButtonStyle}" Width="24" Height="24" Padding="0"
                        ToolTipService.ToolTip="Details view">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8FD;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" Width="24" Height="24" Padding="0"
                        ToolTipService.ToolTip="Tiles view">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8A9;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Progress drawer -->
        <InfoBar x:Name="OperationProgressBar" Grid.Row="3"
                 VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="16"
                 IsOpen="False" Severity="Informational" IsClosable="True">
            <ProgressBar x:Name="OperationProgress" Minimum="0" Maximum="100" Width="200" />
        </InfoBar>

        <!-- Error InfoBar -->
        <InfoBar x:Name="ErrorInfoBar" Grid.Row="3"
                 VerticalAlignment="Top" HorizontalAlignment="Stretch"
                 IsOpen="False" Severity="Error" IsClosable="True" />
    </Grid>
</Window>
