<?xml version="1.0" encoding="utf-8"?>
<!--
  AOT Publish Profile
  
  AOT Compatibility Notes:
  - COM interop in ShellIntegrationService (IContextMenu, IShellFolder) requires 
    [DynamicDependency] attributes on consuming methods. These are marked in the source.
  - The WScript.Shell COM usage in CreateDesktopShortcutAsync uses late-bound dynamic dispatch 
    which is NOT AOT-compatible. An alternative IShellLink P/Invoke implementation should be 
    used for AOT builds.
  - CommunityToolkit.Mvvm source generators are AOT-compatible.
  - Cloud Filter API (cfapi.dll) calls are plain P/Invoke and fully AOT-safe.
  - Serilog file sink uses reflection internally; include rd.xml entries if trimming issues arise.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Configuration>Release</Configuration>
    <PublishDir>bin\publish\aot\</PublishDir>
    <SelfContained>true</SelfContained>
    <PublishAot>true</PublishAot>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- AOT requires trimming -->
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>link</TrimMode>
  </PropertyGroup>
  
  <ItemGroup>
    <!-- Preserve COM interop types needed for shell context menu -->
    <TrimmerRootAssembly Include="FileExplorer.Infrastructure" />
  </ItemGroup>
</Project>
